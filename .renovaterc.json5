{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "local>hayden/renovate-config",
    "local>hayden/phoebe//.renovate/groups.json5",
    "local>hayden/phoebe//.renovate/autoMerge.json5",
  ],
  ignorePaths: [
    "**/*.sops.*",
    "**/resources/**",
  ],
  flux: {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml$/"],
  },
  argocd: {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml$/"],
  },
  "helm-values": {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml$/"],
  },
}
